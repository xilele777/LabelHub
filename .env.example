# ============================================================
# LabelHub 环境变量配置（前端）
# ============================================================
# 复制此文件为 .env 或 .env.local 后修改
# ============================================================

# 前端 API 基础路径（开发时通过 Vite proxy 转发，通常无需修改）
# VITE_API_BASE_URL=/api

# 前端 WebSocket 连接地址（开发环境会自动使用 Vite proxy）
# VITE_WS_URL=http://localhost:3001

# Vite 开发服务器端口
# VITE_DEV_PORT=3000

# Vite 开发服务器绑定地址
# VITE_DEV_HOST=127.0.0.1

# Vite 预览服务器端口
# VITE_PREVIEW_PORT=4173

# Vite 预览服务器绑定地址
# VITE_PREVIEW_HOST=127.0.0.1

# 应用基础路径（部署到子路径时设置，如 /labelhub/）
# VITE_APP_BASE=/

# API 代理目标（Vite dev server 使用）
# VITE_API_PROXY_TARGET=http://localhost:3001