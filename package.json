{
  "name": "labelhub",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:check": "npm run build && node scripts/check-bundle-size.js",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings 50",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cd server && npm run test:e2e"
  },
  "lint-staged": {
    "*.{ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.16.1",
    "echarts": "^6.1.0",
    "pinia": "^3.0.4",
    "socket.io-client": "^4.8.3",
    "vue": "^3.5.35",
    "vue-draggable-plus": "^0.6.1",
    "vue-router": "^4.6.4",
    "web-vitals": "^5.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^25.9.2",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@vue/test-utils": "^2.4.11",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.31.0",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.0",
    "lint-staged": "^15.2.0",
    "prettier": "^3.3.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "~5.8.0",
    "typescript-eslint": "^8.0.0",
    "unplugin-vue-components": "^32.1.0",
    "vite": "^6.3.0",
    "vitest": "^4.1.9",
    "vue-eslint-parser": "^9.4.0"
  }
}
