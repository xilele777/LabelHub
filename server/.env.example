# ============================================================
# LabelHub 环境变量配置（后端）
# ============================================================
# 复制此文件为 server/.env 后修改
# ============================================================

# ── 数据库 ──────────────────────────────────────────────────
# 数据库类型: "sqlite"（默认）或 "postgres"
DB_TYPE=sqlite

# SQLite 数据库文件路径（仅 DB_TYPE=sqlite 时生效）
# LABELHUB_DB_PATH=./data/labelhub.db

# PostgreSQL 连接串（仅 DB_TYPE=postgres 时生效）
# DATABASE_URL=postgresql://labelhub:labelhub123@localhost:5432/labelhub

# PostgreSQL 连接池配置（仅 DB_TYPE=postgres 时生效）
# PG_POOL_MIN=2
# PG_POOL_MAX=10

# ── Redis ───────────────────────────────────────────────────
# Redis 连接串（设置后启用: 多进程 WebSocket 互通 + 分布式登录限流）
# 不设置时: WebSocket 仅单进程可用、登录限流使用内存模式
# REDIS_URL=redis://localhost:6379

# ── 服务端口 ────────────────────────────────────────────────
# 后端服务端口
PORT=3001

# ── 安全 ────────────────────────────────────────────────────
# 运行环境: "development" 或 "production"
NODE_ENV=development

# Token 签名密钥（生产环境必须设置，否则使用硬编码开发密钥）
# HMAC_SECRET=your-secret-key-change-in-production
# 或
# LABELHUB_TOKEN_SECRET=your-secret-key-change-in-production

# ── CORS ────────────────────────────────────────────────────
# 允许的前端来源（生产环境必须设置，多个用逗号分隔）
# CORS_ORIGIN=http://localhost:3000
# 或
# CORS_ORIGINS=http://localhost:3000,https://your-domain.com

# 是否信任反向代理的 X-Forwarded-* 头（Nginx / Traefik 等后面设为 true）
# TRUST_PROXY=false

# ── 限流 ────────────────────────────────────────────────────
# 登录限流窗口（毫秒）
# LOGIN_RATE_LIMIT_WINDOW_MS=900000

# 登录限流窗口内最大失败次数
# LOGIN_RATE_LIMIT_MAX=5

# ── 分页 ────────────────────────────────────────────────────
# 列表查询最大每页条数
# MAX_PAGE_LIMIT=200

# ── 批量导入 ────────────────────────────────────────────────
# 批量导入最大条目数
# MAX_BATCH_IMPORT_ITEMS=1000